<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Unica+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/styles.css" />
    <title>New Message</title>
  </head>
  <body>
    <%- include("partials/header.ejs")%>
    <main>
      <% if(!locals.currentUser) {%>
        <%- include("partials/loginFirst.ejs")%>
      <%} else {%>
        <div class="form-container message">
          <form action="/posts/new" method="post">
            <legend>Write a New Message</legend>
            <label for="message">Message: </label>
            <textarea 
            name="message" 
            id="message"
            minlength="1"
            maxlength="255"
            placeholder="Must be less than 255 characters"></textarea>
            <%- include("partials/errors.ejs") %>
            <button type="submit">Post</button>
          </form>
        </div>
        <%}%>
    </main>
  </body>
</html>
