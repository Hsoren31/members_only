<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Unica+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Members Only</title>
  </head>
  <body>
    <%- include("partials/header.ejs") %>
    <main>
      <section class="banner">
        <div class="form_desc">
          <h2>Welcome!</h2>
          <p>Members only is an online platform for people to share their thoughts. All posts are anonymous until you become a member.</p>
        </div>
        <div class="login form-container">
            <form class="form_login" action="/log-in" method="post">
              <legend>Login</legend>
              <div class="form-group">
                <label for="username">Username: </label>
                <input id="username" name="username" placeholder="username" type="text" minlength="8" maxlength="15"/>  
              </div>
              <div class="form-group">
                <label for="password">Password: </label>
                <input type="password" name="password" id="password" placeholder="password" minlength="8" maxlength="15"/>  
              </div>
              <button type="submit">Log In</button>
            </form>
            <p>Don't have an account? <a class="sign_up" href="/users/sign-up">Sign-Up</a></p>
        </div>
      </section>
    </main>
  </body>
</html>
